# --------------------------------------------------------------------
# Roamly — environment variables
# Copy to .env.local and fill in only what you need.
# The app runs end-to-end with NO keys (AI_PROVIDER=none, no Supabase).
# --------------------------------------------------------------------

# AI provider: cloud | free | local | auto | none
AI_PROVIDER=none

# Anthropic (used when AI_PROVIDER=cloud or auto)
ANTHROPIC_API_KEY=
ANTHROPIC_PARSE_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_RECOMMEND_MODEL=claude-sonnet-4-6

# Free public AI endpoint (used when AI_PROVIDER=free or auto)
FREE_AI_URL=
FREE_AI_KEY=

# Local LLM (OpenAI-compatible). Examples: llama.cpp server, Ollama, LM Studio
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=

# --------------------------------------------------------------------
# Supabase (optional — leave blank to use local SQLite fallback)
# --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local SQLite path (used when Supabase env is unset)
SQLITE_PATH=./.local/nomadvault.db

# --------------------------------------------------------------------
# Map
# --------------------------------------------------------------------
# Mapbox token. If unset, the app falls back to Leaflet + OSM tiles.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --------------------------------------------------------------------
# App
# --------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Roamly
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backup nag threshold (days). The app will remind the user to back up
# if no backup has occurred in this many days.
BACKUP_NAG_DAYS=7
